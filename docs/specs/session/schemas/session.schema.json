{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opspilot.dev/schemas/session.schema.json",
  "title": "Session Meta",
  "description": "Top-level OpsPilot Session metadata (JSON equivalent of meta.yaml)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schema_version",
    "owner",
    "playbook",
    "model",
    "status",
    "created_at",
    "updated_at",
    "retention_class",
    "sensitivity"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^sess_[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "ULID-based session id"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "owner": {
      "type": "string",
      "description": "Email or user id"
    },
    "collaborators": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "playbook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "prompts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "version"],
        "properties": {
          "id": { "type": "string" },
          "version": { "type": "string" }
        }
      },
      "default": []
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_id", "kind", "name", "version"],
      "description": "Model reference; provider_id must be registered in providers/templates/provider-registry. Equivalent to model_ref = <provider_id>/<name>@<version>",
      "properties": {
        "provider_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]{1,63}$",
          "description": "Provider instance id (from providers/templates/provider-registry)"
        },
        "kind": {
          "type": "string",
          "enum": [
            "ollama",
            "openrouter",
            "openai",
            "anthropic",
            "gemini",
            "grok",
            "openai_compatible"
          ],
          "description": "Provider kind; consistent with providers/schemas/provider-config.schema.json"
        },
        "name": {
          "type": "string",
          "description": "Model name (without version); includes the vendor prefix when routed via OpenRouter, e.g. anthropic/claude-sonnet-4-6"
        },
        "version": {
          "type": "string",
          "not": { "enum": ["latest", "auto", "stable", ""] },
          "description": "Explicit vendor version string or date; latest / auto / stable / empty are forbidden"
        },
        "alias_used": {
          "type": ["string", "null"],
          "description": "If resolved via a registry alias (e.g. @chat-strong), records the original alias"
        },
        "params": {
          "type": "object",
          "properties": {
            "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
            "top_p": { "type": "number", "minimum": 0, "maximum": 1 },
            "max_tokens": { "type": "integer", "minimum": 1 },
            "seed": { "type": "integer" }
          },
          "additionalProperties": true
        },
        "provider_config_hash": {
          "type": ["string", "null"],
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "sha256 of the matched provider config; used for audit and drift detection"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "paused", "aborted", "archived", "purged"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "parent_id": {
      "type": ["string", "null"],
      "pattern": "^sess_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "retention_class": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "sensitivity": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "labels": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "default": {}
    },
    "extensions": {
      "type": "object",
      "description": "Vendor-specific extension namespace; keys must be vendor identifiers",
      "additionalProperties": { "type": "object" },
      "default": {}
    }
  }
}

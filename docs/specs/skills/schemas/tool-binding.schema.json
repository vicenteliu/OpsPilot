{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opspilot.dev/schemas/tool-binding.schema.json",
  "title": "Skill Tool Binding",
  "description": "Binds a skill's required tool/MCP names to concrete implementations + safety policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["skill_ref", "bindings"],
  "properties": {
    "skill_ref": { "type": "string" },
    "bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tool", "kind", "safety_class", "approval_required"],
        "properties": {
          "tool": {
            "type": "string",
            "description": "Tool name as referenced in SKILL.md.requires.tools or .requires.mcps"
          },
          "kind": {
            "type": "string",
            "enum": ["builtin", "mcp", "sandbox"]
          },
          "mcp_id": {
            "type": ["string", "null"],
            "description": "Required when kind=mcp; must match an mcp-config entry"
          },
          "sandbox_class": {
            "type": ["string", "null"],
            "description": "Required when kind=sandbox; matches sandbox/policies/resource-quota.template.yaml#action_classes",
            "examples": ["shell.read_only", "script.python", "sql.readonly"]
          },
          "safety_class": {
            "type": "string",
            "enum": ["read", "write", "execute", "sensitive"]
          },
          "approval_required": { "type": "boolean" },
          "rate_limit": {
            "type": "object",
            "properties": {
              "rpm": { "type": "integer", "minimum": 1 },
              "per_session_max": { "type": "integer", "minimum": 1 }
            }
          },
          "timeout_ms": { "type": "integer", "minimum": 100 },
          "config": {
            "type": "object",
            "description": "Tool-specific defaults; merged with caller-provided args at invocation",
            "additionalProperties": true
          }
        },
        "allOf": [
          {
            "if": { "properties": { "kind": { "const": "mcp" } } },
            "then": { "required": ["mcp_id"] }
          },
          {
            "if": { "properties": { "kind": { "const": "sandbox" } } },
            "then": { "required": ["sandbox_class"] }
          }
        ]
      }
    },
    "global_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "deny_on_unknown_tool": { "type": "boolean", "default": true },
        "max_total_calls_per_invocation": { "type": "integer", "minimum": 1 },
        "max_total_cost_usd_per_invocation": { "type": "number", "minimum": 0 }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opspilot.dev/schemas/request-fulfillment-v1.schema.json",
  "title": "Request Fulfillment v1",
  "description": "Structured artifact emitted by pb_request_fulfillment_* playbooks under the Work item model. Shares the base contract with incident_summary_v1 (work_item_ref, work_item_type, summary, tasks[], missing_fields, citations) and adds a service-request extension (requested_item, approval_needed). All fields are advisory — the external system of record owns final values (ADR-0006).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_item_ref",
    "work_item_type",
    "summary",
    "requested_item",
    "approval_needed",
    "tasks",
    "missing_fields",
    "citations"
  ],
  "properties": {
    "_comment": {
      "type": "string",
      "description": "Optional human note; ignored by validators."
    },
    "schema_version": {
      "const": "request_fulfillment_v1"
    },
    "work_item_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Work item external identifier (already redacted)."
    },
    "work_item_type": {
      "const": "service_request"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "One-paragraph synthesis suitable for a service-desk lead."
    },
    "requested_item": {
      "type": "string",
      "minLength": 1,
      "description": "What is being asked for (access, reset, provisioning, ...)."
    },
    "approval_needed": {
      "type": "boolean",
      "description": "Whether fulfilling the request requires sign-off."
    },
    "missing_fields": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "description": "Fulfillment steps as assignable, tiered tasks (advisory).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "action", "rationale", "tier"],
        "properties": {
          "ref": {
            "type": "string",
            "pattern": "^task-[0-9]+$",
            "description": "Local task handle, e.g. 'task-1'."
          },
          "action": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "tier": {
            "type": "string",
            "enum": ["L1", "L2", "L3"],
            "description": "Suggested support line — not an assignment."
          },
          "citations": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          }
        }
      }
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "chunk_id", "document_id"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^kb-[0-9]+$",
            "description": "Local citation handle, e.g. 'kb-1'."
          },
          "chunk_id": {
            "type": "string",
            "pattern": "^chk_[a-f0-9]{8}$"
          },
          "document_id": {
            "type": "string",
            "pattern": "^doc_[a-f0-9]{8}$"
          },
          "source_path": { "type": "string" },
          "line_start": { "type": "integer", "minimum": 1 },
          "line_end": { "type": "integer", "minimum": 1 },
          "anchor": { "type": ["string", "null"] },
          "heading_path": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          }
        }
      }
    }
  }
}

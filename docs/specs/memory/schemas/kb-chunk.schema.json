{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opspilot.dev/schemas/kb-chunk.schema.json",
  "title": "KB Chunk",
  "description": "KB chunk metadata; the vectors themselves live in LanceDB. This schema describes the SQLite metadata row plus the LanceDB reference",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "document_id",
    "seq",
    "content_hash",
    "char_start",
    "char_end",
    "line_start",
    "line_end",
    "embedding_model",
    "vector_id"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^chk_[a-f0-9]{8}$"
    },
    "document_id": {
      "type": "string",
      "pattern": "^doc_[a-f0-9]{8}$"
    },
    "seq": {
      "type": "integer",
      "minimum": 0,
      "description": "Ordinal sequence number within the document"
    },
    "content": {
      "type": ["string", "null"],
      "description": "Redacted chunk text; null when larger than 8 KiB, in which case the body goes to an artifact"
    },
    "content_artifact_id": {
      "type": ["string", "null"],
      "pattern": "^art_[a-f0-9]{16}$"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "char_start": { "type": "integer", "minimum": 0 },
    "char_end": { "type": "integer", "minimum": 0 },
    "line_start": { "type": "integer", "minimum": 1 },
    "line_end": { "type": "integer", "minimum": 1 },
    "heading_path": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Heading breadcrumb, e.g. ['VPN SOP','Troubleshooting','Authentication errors']"
    },
    "anchor": {
      "type": ["string", "null"],
      "description": "Markdown anchor or fragment, e.g. '#troubleshooting-authentication-errors'"
    },
    "token_count": { "type": "integer", "minimum": 1 },
    "embedding_model": {
      "type": "string",
      "not": { "pattern": "@(latest|auto|stable)$" }
    },
    "vector_id": {
      "type": "string",
      "description": "LanceDB row primary key; one-to-one with the SQLite chunk row"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "namespace": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*:[a-z][a-z0-9_-]*$"
        },
        "classification": {
          "type": "string",
          "enum": ["public", "internal", "confidential", "restricted"]
        },
        "language": { "type": "string" }
      },
      "required": ["namespace", "classification"]
    }
  }
}

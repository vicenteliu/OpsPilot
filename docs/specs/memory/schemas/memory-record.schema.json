{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opspilot.dev/schemas/memory-record.schema.json",
  "title": "Memory Record (mid-term)",
  "description": "Structured record for mid-term memory; equivalent to the markdown frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "scope",
    "title",
    "body",
    "source",
    "created_at",
    "updated_at",
    "confidence",
    "redacted"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^mem_[a-f0-9]{8}$",
      "description": "mem_<sha8>; content-addressed"
    },
    "type": {
      "type": "string",
      "enum": ["user", "feedback", "project", "reference"],
      "description": "See SPEC.md §2"
    },
    "scope": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*:[a-z][a-z0-9_-]*$",
      "description": "Namespace, e.g. opspilot:user / opspilot:project"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "body": {
      "type": "string",
      "description": "Markdown; feedback/project types must contain **Why:** and **How to apply:** sections"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin"],
      "properties": {
        "origin": {
          "type": "string",
          "enum": ["session", "user_input", "ingest", "system"]
        },
        "session_id": {
          "type": ["string", "null"],
          "pattern": "^sess_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "trace_seq": { "type": ["integer", "null"], "minimum": 0 },
        "document_id": {
          "type": ["string", "null"],
          "pattern": "^doc_[a-f0-9]{8}$"
        },
        "url": {
          "type": ["string", "null"],
          "format": "uri"
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "valid_until": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Explicit expiry time; read-only once expired"
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Affects retrieval weighting; entries confirmed directly by the user are high"
    },
    "redacted": {
      "type": "boolean",
      "const": true,
      "description": "Memory must be redacted before storage; this field must be true"
    },
    "redaction_rules_version": { "type": "string" },
    "labels": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "default": {}
    },
    "extensions": {
      "type": "object",
      "default": {}
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opspilot.dev/schemas/eval-result.schema.json",
  "title": "Eval Result",
  "description": "A single evaluation result (one line of results.jsonl)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "fixture_id",
    "fixture_version",
    "playbook_ref",
    "model_ref",
    "ts",
    "scores",
    "pass",
    "evaluators"
  ],
  "properties": {
    "_comment": { "type": "string" },
    "run_id": { "type": "string", "pattern": "^run_[0-9A-HJKMNP-TV-Z]{26}$" },
    "fixture_id": { "type": "string", "pattern": "^fix_[a-f0-9]{8}$" },
    "fixture_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "playbook_ref": {
      "type": "string",
      "description": "<playbook_id>@<version>"
    },
    "prompt_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "Hash of the full prompt text actually sent to the model"
    },
    "model_ref": {
      "type": "string",
      "description": "<vendor>/<name>@<version>"
    },
    "judge_model_ref": {
      "type": ["string", "null"],
      "description": "If an LLM judge is used, a specific version must be given"
    },
    "ts": { "type": "string", "format": "date-time" },

    "output": {
      "type": "object",
      "description": "Actual model output (truncated inline, or referencing an artifact)",
      "properties": {
        "inline": { "type": ["string", "null"], "maxLength": 8192 },
        "artifact_id": { "type": ["string", "null"], "pattern": "^art_[a-f0-9]{16}$" }
      }
    },

    "evaluators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "score", "pass"],
        "properties": {
          "id": { "type": "string", "description": "evaluator config id" },
          "type": {
            "type": "string",
            "enum": [
              "rule.regex",
              "rule.json_schema",
              "rule.pii_check",
              "semantic.embedding",
              "judge.llm",
              "sandbox.exec",
              "rag.recall_at_k",
              "rag.precision_at_k",
              "rag.citation_validity",
              "human.review"
            ]
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "pass": { "type": "boolean" },
          "details": { "type": "object" }
        }
      }
    },

    "scores": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "weighted": { "type": "number", "minimum": 0, "maximum": 1 },
        "by_type": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      },
      "required": ["weighted"]
    },

    "pass": { "type": "boolean", "description": "Aggregate pass status (true when all evaluators pass; may be overridden by config)" },

    "cost": {
      "type": "object",
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "judge_tokens": { "type": "integer", "minimum": 0 },
        "usd": { "type": "number", "minimum": 0 }
      }
    },

    "latency_ms": {
      "type": "object",
      "properties": {
        "model_p50": { "type": "integer", "minimum": 0 },
        "end_to_end": { "type": "integer", "minimum": 0 }
      }
    },

    "flags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["nondeterministic", "redaction_warning", "judge_low_confidence", "manual_review_pending", "cost_gate_failed"]
      }
    },

    "extensions": { "type": "object", "default": {} },

    "iteration_meta": {
      "type": "object",
      "description": "Optional cross-link to a skills iteration when this result is a variant evaluation. See skills/ITERATION.md.",
      "additionalProperties": true,
      "properties": {
        "iteration_id": { "type": "string", "pattern": "^itr_[0-9A-HJKMNP-TV-Z]{26}$" },
        "variant_id": { "type": "string", "pattern": "^var_[a-f0-9]{8}$" },
        "baseline_run_id": { "type": "string", "pattern": "^run_[0-9A-HJKMNP-TV-Z]{26}$" },
        "delta_vs_baseline": { "type": "object" },
        "promotion_gate_result": { "type": "object" }
      }
    }
  }
}

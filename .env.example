# OpsPilot environment variables (example).
# Copy to .env and fill in. .env is gitignored.

# Where OpsPilot stores per-user state (KB, sessions, audit logs).
# Defaults to ~/.opspilot when unset. If you override it, use an absolute
# path — $HOME is not expanded when HOME is unset (containers, systemd),
# which silently creates a literal "$HOME/" directory in the workdir.
# OPSPILOT_HOME=/absolute/path/to/state-dir

# API bearer token (ADR-0011). Required to bind beyond loopback; every
# endpoint except /health then needs "Authorization: Bearer <token>".
# Generate one with: openssl rand -hex 32
# OPSPILOT_API_TOKEN=

# Logging
OPSPILOT_LOG_LEVEL=INFO

# Ollama (local, no key needed)
OPSPILOT_OLLAMA_BASE_URL=http://localhost:11434
# Request timeout in seconds. Raise for large local models (e.g. gemma4:12b)
# that take longer to cold-load + generate.
OPSPILOT_OLLAMA_TIMEOUT_S=300

# Telegram channel adapter (assist mode) — see docs/channels.md.
# TELEGRAM_BOT_TOKEN=

# Cloud providers — fill in whichever you use.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
# GEMINI_API_KEY=...
# GROK_API_KEY=xai-...

# OpsPilot environment variables (example).
# Copy to .env and fill in. .env is gitignored.

# Where OpsPilot stores per-user state (KB, sessions, audit logs).
OPSPILOT_HOME=$HOME/.opspilot

# Logging
OPSPILOT_LOG_LEVEL=INFO

# Ollama (local, no key needed)
OPSPILOT_OLLAMA_BASE_URL=http://localhost:11434
# Request timeout in seconds. Raise for large local models (e.g. gemma4:12b)
# that take longer to cold-load + generate.
OPSPILOT_OLLAMA_TIMEOUT_S=300

# Cloud providers — fill in whichever you use.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
# GEMINI_API_KEY=...
# GROK_API_KEY=xai-...

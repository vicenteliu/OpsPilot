# OpsPilot Stage 1 environment variables (example).
# Copy to .env and fill in. .env is gitignored.

# Where OpsPilot stores per-user state (KB, sessions, audit logs).
OPSPILOT_HOME=$HOME/.opspilot

# Logging
OPSPILOT_LOG_LEVEL=INFO

# Stage 1: Ollama is the only provider (no API key needed).
OPSPILOT_OLLAMA_BASE_URL=http://localhost:11434

# Stage 2+ will add (kept here as placeholders, do NOT fill yet):
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=...
# GEMINI_API_KEY=...
# XAI_API_KEY=...

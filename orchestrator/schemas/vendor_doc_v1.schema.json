{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opspilot.dev/schemas/vendor-doc-v1.schema.json",
  "title": "Vendor Doc v1",
  "description": "Structured operational document generated from KB for external vendors.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "doc_ref",
    "template_id",
    "title",
    "sections",
    "citations"
  ],
  "properties": {
    "schema_version": {
      "const": "vendor_doc_v1"
    },
    "doc_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Unique document reference, e.g. VDOC-20260506-001."
    },
    "template_id": {
      "type": "string",
      "enum": ["sop_summary", "maintenance_window", "incident_report", "handover"],
      "description": "Which document template was applied."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Document title suitable for the vendor."
    },
    "sections": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["heading", "content"],
        "properties": {
          "heading": { "type": "string", "minLength": 1 },
          "content": { "type": "string", "minLength": 1 },
          "citations": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          }
        }
      }
    },
    "scope_note": {
      "type": ["string", "null"],
      "description": "One sentence on applicability / audience."
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "chunk_id", "document_id"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^kb-[0-9]+$"
          },
          "chunk_id": {
            "type": "string",
            "pattern": "^chk_[a-f0-9]{8}$"
          },
          "document_id": {
            "type": "string",
            "pattern": "^doc_[a-f0-9]{8}$"
          },
          "source_path": { "type": "string" },
          "line_start": { "type": "integer", "minimum": 1 },
          "line_end": { "type": "integer", "minimum": 1 },
          "anchor": { "type": ["string", "null"] },
          "heading_path": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opspilot.dev/schemas/ticket-summary-v1.schema.json",
  "title": "Ticket Summary v1",
  "description": "Structured artifact emitted by pb_ticket_summary_zh and equivalent playbooks. Promoted from harness/golden.json#schema_check.rules into a standalone JSON Schema for opspilot validate / harness reuse.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ticket_ref",
    "summary",
    "symptoms",
    "scope",
    "tried_steps",
    "missing_fields",
    "next_actions",
    "severity_suggested",
    "citations"
  ],
  "properties": {
    "_comment": {
      "type": "string",
      "description": "Optional human note; ignored by validators."
    },
    "schema_version": {
      "const": "ticket_summary_v1"
    },
    "ticket_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Ticket external identifier (already redacted)."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "One-paragraph synthesis suitable for a service-desk lead."
    },
    "symptoms": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "scope": {
      "type": "string",
      "enum": ["single_user", "multiple_users", "site_wide", "unknown"]
    },
    "tried_steps": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "missing_fields": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "next_actions": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "rationale"],
        "properties": {
          "action": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "citations": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          }
        }
      }
    },
    "severity_suggested": {
      "type": "string",
      "pattern": "^P[0-4]$"
    },
    "escalation_hint": {
      "type": ["string", "null"],
      "description": "Optional one-line routing suggestion (e.g. 'L2 网络组')."
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "chunk_id", "document_id"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^kb-[0-9]+$",
            "description": "Local citation handle, e.g. 'kb-1'."
          },
          "chunk_id": {
            "type": "string",
            "pattern": "^chk_[a-f0-9]{8}$"
          },
          "document_id": {
            "type": "string",
            "pattern": "^doc_[a-f0-9]{8}$"
          },
          "source_path": { "type": "string" },
          "line_start": { "type": "integer", "minimum": 1 },
          "line_end": { "type": "integer", "minimum": 1 },
          "anchor": { "type": ["string", "null"] },
          "heading_path": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opspilot.dev/schemas/wiki-page.schema.json",
  "title": "Wiki Page",
  "description": "Frontmatter for a wiki page; body is markdown",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "page_id",
    "slug",
    "kind",
    "title",
    "summary",
    "namespace",
    "classification",
    "language",
    "version",
    "created_at",
    "updated_at",
    "derived_from",
    "outbound_links",
    "inbound_link_count",
    "redacted",
    "lifecycle_state",
    "owner"
  ],
  "properties": {
    "page_id": {
      "type": "string",
      "pattern": "^wpg_[a-f0-9]{8}$",
      "description": "wpg_<sha256(canonical frontmatter+body)[:8]>"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "minLength": 2,
      "maxLength": 80,
      "description": "Globally unique slug; used in [[<slug>]] cross-links"
    },
    "kind": {
      "type": "string",
      "enum": ["entity", "concept", "summary", "comparison", "synthesis"]
    },
    "title": { "type": "string", "minLength": 1, "maxLength": 200 },
    "summary": { "type": "string", "minLength": 10, "maxLength": 200 },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*:[a-z][a-z0-9_-]*$"
    },
    "classification": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted"]
    },
    "language": { "type": "string", "examples": ["zh-CN", "en", "mixed"] },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },

    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Alternative names matched by lint when looking up cross-references"
    },

    "derived_from": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sources"],
      "properties": {
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "ref"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["kb_document", "session", "external_url", "wiki_page"]
              },
              "ref": {
                "type": "string",
                "description": "doc_id / sess_id / URL / wpg_id depending on kind"
              },
              "sha256": {
                "type": ["string", "null"],
                "pattern": "^sha256:[a-f0-9]{64}$"
              },
              "line_start": { "type": ["integer", "null"], "minimum": 1 },
              "line_end": { "type": ["integer", "null"], "minimum": 1 }
            }
          }
        },
        "parent_pages": {
          "type": "array",
          "items": { "type": "string", "pattern": "^wpg_[a-f0-9]{8}$" },
          "description": "Earlier page versions or pages this one extends"
        }
      }
    },

    "outbound_links": {
      "type": "array",
      "items": { "type": "string", "pattern": "^wpg_[a-f0-9]{8}$" },
      "description": "Machine-maintained; do not hand-edit"
    },
    "inbound_link_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Computed by lint; orphan if 0 (and kind is not index/log)"
    },

    "redacted": { "type": "boolean", "const": true },
    "redaction_rules_version": { "type": "string" },

    "lifecycle_state": {
      "type": "string",
      "enum": ["draft", "reviewed", "live", "stale", "archived"]
    },

    "owner": { "type": "string" },
    "collaborators": {
      "type": "array",
      "items": { "type": "string" }
    },

    "kb_registration": {
      "type": "object",
      "description": "Set when this page is registered back to memory KB",
      "additionalProperties": false,
      "properties": {
        "kb_doc_id": { "type": "string", "pattern": "^doc_[a-f0-9]{8}$" },
        "registered_at": { "type": "string", "format": "date-time" },
        "embedding_model": { "type": "string" },
        "chunk_count": { "type": "integer", "minimum": 0 }
      }
    },

    "lint_state": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "last_linted_at": { "type": "string", "format": "date-time" },
        "open_issue_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^lnt_[a-f0-9]{8}$" }
        }
      }
    },

    "extensions": { "type": "object" }
  },

  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "entity" } } },
      "then": {
        "properties": {
          "extensions": {
            "type": "object",
            "properties": {
              "entity": {
                "type": "object",
                "properties": {
                  "related_entities": { "type": "array", "items": { "type": "string" } },
                  "related_concepts": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "summary" } } },
      "then": {
        "properties": {
          "extensions": {
            "type": "object",
            "properties": {
              "summary": {
                "type": "object",
                "required": ["source_doc_id"],
                "properties": {
                  "source_doc_id": { "type": "string", "pattern": "^doc_[a-f0-9]{8}$" },
                  "source_uri": { "type": ["string", "null"] }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "comparison" } } },
      "then": {
        "properties": {
          "extensions": {
            "type": "object",
            "properties": {
              "comparison": {
                "type": "object",
                "required": ["subjects"],
                "properties": {
                  "subjects": {
                    "type": "array",
                    "minItems": 2,
                    "items": { "type": "string" }
                  },
                  "criteria": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "synthesis" } } },
      "then": {
        "properties": {
          "extensions": {
            "type": "object",
            "properties": {
              "synthesis": {
                "type": "object",
                "required": ["thesis"],
                "properties": {
                  "thesis": { "type": "string", "maxLength": 300 },
                  "evidence_count": { "type": "integer", "minimum": 0 },
                  "counter_evidence_count": { "type": "integer", "minimum": 0 }
                }
              }
            }
          }
        }
      }
    }
  ]
}

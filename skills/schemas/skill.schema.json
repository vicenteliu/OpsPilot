{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opspilot.dev/schemas/skill.schema.json",
  "title": "Skill",
  "description": "SKILL.md frontmatter; the body (markdown after frontmatter) is the instruction text",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "description",
    "version",
    "language",
    "author",
    "source",
    "license",
    "model_compat",
    "safety",
    "redacted"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^([a-z][a-z0-9_-]*:)?[a-z][a-z0-9_-]{1,63}$",
      "description": "Unique slug; supports `<plugin>:<name>` namespacing"
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "maxLength": 300,
      "description": "Single-line trigger description (≤300 chars). See SPEC.md §3 for tuning rules."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "not": { "enum": ["latest", "auto", "stable"] }
    },
    "language": {
      "type": "string",
      "examples": ["en", "zh-CN", "mixed"]
    },
    "author": { "type": "string" },
    "source": {
      "type": "string",
      "enum": [
        "self_authored",
        "distilled",
        "imported_trusted",
        "imported_community",
        "imported_unknown"
      ]
    },
    "license": {
      "type": "string",
      "description": "SPDX identifier (e.g. MIT, Apache-2.0) or 'proprietary'"
    },
    "model_compat": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "description": "model_ref / alias from providers; or 'any'"
      }
    },
    "requires": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tools": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Builtin tools (e.g. kb.search, memory.add, artifact.write)"
        },
        "mcps": {
          "type": "array",
          "items": { "type": "string" },
          "description": "MCP server ids registered in mcp-config"
        },
        "providers": {
          "type": "object",
          "description": "Provider capability constraints (any registered provider satisfying these is acceptable)",
          "properties": {
            "tools": { "type": "boolean" },
            "vision": { "type": "boolean" },
            "json_mode": { "type": "boolean" },
            "long_context_tokens": { "type": "integer", "minimum": 0 },
            "embeddings": { "type": "boolean" }
          }
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Other skills this skill depends on; format <name>@<version>"
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "approval_required", "telemetry_optout"],
      "properties": {
        "classification": {
          "type": "string",
          "enum": ["public", "internal", "confidential", "restricted"]
        },
        "approval_required": { "type": "boolean" },
        "telemetry_optout": { "type": "boolean" },
        "pii_allowed": { "type": "boolean", "default": false }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_ref": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_ref": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "distillation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "sources"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["from_traces", "from_skills", "from_docs", "from_foreign"]
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Refs to source data (session_ids / skill_refs / doc_paths / foreign URLs)"
        },
        "pipeline_run": { "type": "string", "pattern": "^run_[0-9A-HJKMNP-TV-Z]{26}$" },
        "distilled_at": { "type": "string", "format": "date-time" },
        "redaction_rules_version": { "type": "string" }
      }
    },
    "redacted": {
      "type": "boolean",
      "const": true,
      "description": "Body must be redacted before publishing"
    },
    "redaction_rules_version": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "labels": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}

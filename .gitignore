# PyCharm
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Abstra
# Abstra is an AI-powered process automation framework.
# Ignore directories containing user credentials, local state, and settings.
# Learn more at https://abstra.io/docs
.abstra/

# Visual Studio Code
#  Visual Studio Code specific template is maintained in a separate VisualStudioCode.gitignore 
#  that can be found at https://github.com/github/gitignore/blob/main/Global/VisualStudioCode.gitignore
#  and can be added to the global gitignore or merged into this file. However, if you prefer, 
#  you could uncomment the following to ignore the entire vscode folder
# .vscode/

# Ruff stuff:
.ruff_cache/

# PyPI configuration file
.pypirc

# Cursor
#  Cursor is an AI-powered code editor. `.cursorignore` specifies files/directories to
#  exclude from AI features like autocomplete and code analysis. Recommended for sensitive data
#  refer to https://docs.cursor.com/context/ignore-files
.cursorignore
.cursorindexingignore

# Marimo
marimo/_static/
marimo/_lsp/
__marimo__/

# OpsPilot — memory & KB derived data (never committed; markdown sources are
# authoritative). SQL/MD files under docs/specs/memory/storage are schema
# docs and are NOT ignored here.
*.lance/
**/lancedb/
**/kb/*/lancedb/
**/kb/*/meta.db
**/kb/*/meta.db-*
**/kb/*/snapshots/
**/kb/*/quarantine/
**/kb/*/embed-pending/
**/kb/*/redacted/
**/kb/*/audit.log
**/kb/*/manifest.jsonl
**/kb/*/progress.jsonl
**/kb/*/low-score-queries.jsonl

# OpsPilot — mid-term memory local storage (private; never committed)
.opspilot/
# Literal "$HOME/" dir created when OPSPILOT_HOME=$HOME/... is read in an
# environment where HOME is unset (containers, systemd) — see .env.example
/$HOME/
**/memory/mid-term.db
**/memory/mid-term.db-*
**/memory/backups/
**/memory/review-queue.jsonl

# OpsPilot — session local data (sensitive; never committed)
sessions/

# OpsPilot — e2e sample logs under examples/ are spec artifacts and ARE
# committed (compensates the overly-broad Django-style *.log pattern above)
!examples/**/audit.log
!examples/**/*.log

# OpsPilot — secrets (API keys always come from env or a broker)
.env
.env.*
!.env.example
.git-commit-msg*

# OpsPilot ships its own .envrc at repo root with no secrets (just dotenv loader
# + venv activation); allow it explicitly. The Python "Environments" block above
# still ignores .envrc anywhere else.
!/.envrc

# harness run outputs
golden-results.jsonl
harness-results-*.jsonl

# Claude Code tooling (machine-local; not shared)
.agents/
.claude/
.serena/
# Root-anchored: machine-local installed skills live in /skills/, while the
# tracked skill SPEC lives in docs/specs/skills/ and must NOT be ignored
/skills/
skills-lock.json

# pytest-cache leftovers occasionally dropped in the repo root
pytest-cache-files-*/

# Svelte / Node
web/node_modules/
web/.svelte-kit/
!web/src/lib/

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opspilot.dev/schemas/eval-result.schema.json",
  "title": "Eval Result",
  "description": "一次评估单条结果（results.jsonl 的一行）",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "fixture_id",
    "fixture_version",
    "playbook_ref",
    "model_ref",
    "ts",
    "scores",
    "pass",
    "evaluators"
  ],
  "properties": {
    "run_id": { "type": "string", "pattern": "^run_[0-9A-HJKMNP-TV-Z]{26}$" },
    "fixture_id": { "type": "string", "pattern": "^fix_[a-f0-9]{8}$" },
    "fixture_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "playbook_ref": {
      "type": "string",
      "description": "<playbook_id>@<version>"
    },
    "prompt_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "实际下发到模型的 prompt 全文 hash"
    },
    "model_ref": {
      "type": "string",
      "description": "<vendor>/<name>@<version>"
    },
    "judge_model_ref": {
      "type": ["string", "null"],
      "description": "若使用 LLM-judge，必须填具体版本"
    },
    "ts": { "type": "string", "format": "date-time" },

    "output": {
      "type": "object",
      "description": "模型实际输出（截断或引用 artifact）",
      "properties": {
        "inline": { "type": ["string", "null"], "maxLength": 8192 },
        "artifact_id": { "type": ["string", "null"], "pattern": "^art_[a-f0-9]{16}$" }
      }
    },

    "evaluators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "score", "pass"],
        "properties": {
          "id": { "type": "string", "description": "evaluator 配置 id" },
          "type": {
            "type": "string",
            "enum": [
              "rule.regex",
              "rule.json_schema",
              "rule.pii_check",
              "semantic.embedding",
              "judge.llm",
              "sandbox.exec",
              "human.review"
            ]
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "pass": { "type": "boolean" },
          "details": { "type": "object" }
        }
      }
    },

    "scores": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "weighted": { "type": "number", "minimum": 0, "maximum": 1 },
        "by_type": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      },
      "required": ["weighted"]
    },

    "pass": { "type": "boolean", "description": "聚合通过状态（全部 evaluator pass 视为 true，可被 config 覆盖）" },

    "cost": {
      "type": "object",
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "judge_tokens": { "type": "integer", "minimum": 0 },
        "usd": { "type": "number", "minimum": 0 }
      }
    },

    "latency_ms": {
      "type": "object",
      "properties": {
        "model_p50": { "type": "integer", "minimum": 0 },
        "end_to_end": { "type": "integer", "minimum": 0 }
      }
    },

    "flags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["nondeterministic", "redaction_warning", "judge_low_confidence", "manual_review_pending"]
      }
    },

    "extensions": { "type": "object", "default": {} }
  }
}
